{
	"name": "@xernerx/terminal",
	"publishConfig": {
		"access": "public"
	},
	"version": "1.0.12",
	"type": "module",
	"description": "A cli log tool for xernerx projects",
	"main": "./dist/main.cjs",
	"module": "./dist/main.js",
	"types": "./dist/main.d.ts",
	"homepage": "www.xernerx.com",
	"files": [
		"src",
		"dist"
	],
	"exports": {
		"require": {
			"types": "./dist/main.d.cts",
			"default": "./dist/main.cjs"
		},
		"import": {
			"types": "./dist/main.d.ts",
			"default": "./dist/main.js"
		}
	},
	"scripts": {
		"beta": "npm version prerelease --preid=beta",
		"patch": "npm version patch",
		"minor": "npm version minor",
		"major": "npm version major",
		"docs": "npx typedoc",
		"build": "npm i && npx tsup && npx @arethetypeswrong/cli --pack && npm run docs",
		"dev": "npm i && npm link && npx tsup --watch",
		"test": "npm install --engine-strict=true",
		"pub": "git add . && git commit -m \"type update\" && npm run patch && git push origin main"
	},
	"keywords": [],
	"author": "Xernerx Studios",
	"license": "MIT",
	"packageManager": "npm@11.11.0",
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@types/chalk-animation": "^1.6.3",
		"@types/node": "^24",
		"prettier": "^3.8.3",
		"tsup": "^8.5.1",
		"typedoc-github-theme": "^0.4.0",
		"typedoc-plugin-extras": "^4.0.1",
		"typedoc-plugin-zod": "^1.4.3",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"boxen": "^8.0.1",
		"chalk": "^5.6.2",
		"ora": "^9.4.0"
	},
	"engines": {
		"node": ">=24"
	}
}
